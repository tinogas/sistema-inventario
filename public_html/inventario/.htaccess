# ============================================================
# Sistema de Inventario - Configuración Apache / cPanel
# ============================================================

Options -Indexes
Options -ExecCGI

# ---- Seguridad: bloquear acceso a carpetas del sistema ----
RewriteEngine On

RewriteRule ^config/     - [F,L]
RewriteRule ^core/       - [F,L]
RewriteRule ^modules/    - [F,L]
RewriteRule ^shared/     - [F,L]

# ---- Headers de seguridad ----
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# ---- PHP: ocultar versión y errores en producción ----
<IfModule mod_php8.c>
    php_flag display_errors off
    php_flag expose_php off
    php_value session.cookie_httponly 1
    php_value session.use_strict_mode 1
    php_value session.cookie_samesite Strict
</IfModule>

# ---- Proteger archivos sensibles ----
<FilesMatch "\.(sql|log|env|md|json|lock|sh)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# ---- Cache de assets estáticos ----
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css              "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png             "access plus 6 months"
    ExpiresByType image/jpeg            "access plus 6 months"
    ExpiresByType image/svg+xml         "access plus 6 months"
</IfModule>

# ---- Compresión GZIP ----
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>
